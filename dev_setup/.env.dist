# Copy this file to .env and fill in your local values
# .env is gitignored — never commit it

# Path to MurlocVillageCICD repo relative to the azerothcore-wotlk-mv root
CICD_PATH=../MurlocVillageCICD

# Local database host (hostname or IP of your MySQL instance)
DB_HOST=127.0.0.1
DB_PORT=3306

# Database credentials
DB_USER=trinity
DB_PASSWORD=trinitypass

# Database names (must exist locally — import from prod dump or let AC create them)
DB_AUTH=acore_auth
DB_WORLD=world_fondeboue
DB_CHARACTERS=characters_fondeboue

# Local paths
DATA_DIR=/home/clem/MurlocVillageProject/azerothcore-wotlk-mv/env/dist/data
LOGS_DIR=/home/clem/MurlocVillageProject/azerothcore-wotlk-mv/env/dist/logs
